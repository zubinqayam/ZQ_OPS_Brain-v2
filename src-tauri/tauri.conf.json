{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ZQ Ops Brain",
  "version": "2.0.0",
  "identifier": "com.zq-ops.brain",
  "productName": "ZQ Ops Brain v2",
  "version": "2.0.0",
  "identifier": "com.zqops.brain.v2",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZQ Ops Brain - INNM-WOSDS",
        "width": 1200,
        "height": 800,
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "ZQ Ops Brain v2",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc://localhost;"
      "csp": "default-src 'self'; img-src 'self' data:; media-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      {
        "name": "innm-engine",
        "path": "binaries/innm-engine"
      }
    ]
  }
}
